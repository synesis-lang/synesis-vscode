{
  "name": "Synesis Light",
  "type": "light",
  "semanticHighlighting": true,
  "colors": {
    "editor.background": "#faf4ed",
    "editor.foreground": "#575279"
  },
  "semanticTokenColors": {
    "keyword": { "foreground": "#8839ef" },
    "keyword.declaration": { "foreground": "#8839ef", "fontStyle": "bold" },
    "variable": { "foreground": "#df8e1d" },
    "variable.declaration": { "foreground": "#df8e1d", "fontStyle": "underline" },
    "property": { "foreground": "#1e66f5", "fontStyle": "bold" },
    "string": { "foreground": "#40a02b" },
    "enumMember": { "foreground": "#179299" },
    "namespace": { "foreground": "#8839ef", "fontStyle": "bold" },
    "comment": { "foreground": "#9893a5", "fontStyle": "italic" },
    "operator": { "foreground": "#9893a5" },
    "type": { "foreground": "#d20f39", "fontStyle": "bold" }
  },
  "tokenColors": [
    {
      "name": "Keywords — block structure (SOURCE, ITEM, END, ONTOLOGY)",
      "scope": [
        "keyword.control.block.synesis",
        "keyword.control.field.synesis",
        "keyword.control.type.synesis",
        "keyword.control.scope.synesis"
      ],
      "settings": {
        "foreground": "#8839ef",
        "fontStyle": "bold"
      }
    },
    {
      "name": "References (@bibref)",
      "scope": "entity.name.reference.synesis",
      "settings": {
        "foreground": "#df8e1d",
        "fontStyle": "underline"
      }
    },
    {
      "name": "Field Names (code:, text:, method:)",
      "scope": [
        "entity.name.tag.field.synesis",
        "entity.name.field.synesis"
      ],
      "settings": {
        "foreground": "#1e66f5",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Codes — ontology concepts (Trust, CCS_Support)",
      "scope": "variable.other.code.synesis",
      "settings": {
        "foreground": "#179299"
      }
    },
    {
      "name": "Relations (INFLUENCES, ENABLES, CONSTRAINS, ...)",
      "scope": "constant.language.relation.synesis",
      "settings": {
        "foreground": "#d20f39",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Chain Arrows (->)",
      "scope": "keyword.operator.arrow.synesis",
      "settings": {
        "foreground": "#9893a5"
      }
    },
    {
      "name": "Field Values (text content)",
      "scope": [
        "string.quoted.field.synesis",
        "string.unquoted.field.synesis"
      ],
      "settings": {
        "foreground": "#40a02b"
      }
    },
    {
      "name": "Comments",
      "scope": [
        "comment.line.synesis",
        "comment.line.number-sign.synesis"
      ],
      "settings": {
        "foreground": "#9893a5",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Comma Separators",
      "scope": "punctuation.separator.comma.synesis",
      "settings": {
        "foreground": "#9893a5"
      }
    },
    {
      "name": "Guidelines Content (plain instructional text)",
      "scope": "string.unquoted.guidelines.synesis",
      "settings": {
        "foreground": "#6e6a86",
        "fontStyle": "italic"
      }
    }
  ]
}
