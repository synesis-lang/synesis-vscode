{
  "name": "synesis",
  "displayName": "Synesis",
  "description": "Knowledge Engineering in VS Code: Official LSP client for Synesis.",
  "version": "0.7.0",
  "publisher": "synesis-lang",
  "author": "Christian Maciel De Britto",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/synesis-lang/synesis-vscode"
  },
  "bugs": {
    "url": "https://github.com/synesis-lang/synesis-vscode/issues"
  },
  "homepage": "https://github.com/synesis-lang/synesis-vscode#readme",
  "icon": "synesis-icon.png",
  "engines": {
    "vscode": "^1.60.0"
  },
  "categories": [
    "Programming Languages",
    "Linters",
    "Visualization",
    "Other"
  ],
  "keywords": [
    "synesis",
    "qualitative research",
    "knowledge engineering",
    "ontology",
    "CAQDAS"
  ],
  "activationEvents": [
    "workspaceContains:*.synp"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "synesis",
        "aliases": [
          "Synesis",
          "synesis"
        ],
        "extensions": [
          ".syn",
          ".synt",
          ".synp",
          ".syno",
          ".synr"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "synesis",
        "scopeName": "source.synesis",
        "path": "./syntaxes/synesis.tmLanguage.json"
      }
    ],
    "semanticTokenScopes": [
      {
        "language": "synesis",
        "scopes": {
          "keyword": [
            "keyword.control.block.synesis"
          ],
          "variable": [
            "entity.name.reference.synesis"
          ],
          "property": [
            "entity.name.tag.field.synesis"
          ],
          "string": [
            "string.quoted.field.synesis"
          ],
          "enumMember": [
            "variable.other.code.synesis"
          ],
          "namespace": [
            "keyword.control.block.synesis"
          ],
          "comment": [
            "comment.line.synesis"
          ],
          "operator": [
            "keyword.operator.arrow.synesis"
          ],
          "type": [
            "constant.language.relation.synesis"
          ]
        }
      }
    ],
    "themes": [
      {
        "label": "Synesis Dark",
        "uiTheme": "vs-dark",
        "path": "./themes/synesis-dark-theme.json"
      },
      {
        "label": "Synesis Light",
        "uiTheme": "vs",
        "path": "./themes/synesis-light-theme.json"
      }
    ],
    "iconThemes": [
      {
        "id": "synesis-file-icons",
        "label": "Synesis File Icons",
        "path": "./icons/synesis-file-icon-theme.json"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "synesis",
          "title": "Synesis",
          "icon": "synesis-icon.svg"
        }
      ]
    },
    "views": {
      "synesis": [
        {
          "id": "synesisReferenceExplorer",
          "name": "References"
        },
        {
          "id": "synesisCodeExplorer",
          "name": "Codes",
          "when": "synesis.hasCodes"
        },
        {
          "id": "synesisRelationExplorer",
          "name": "Relations",
          "when": "synesis.hasChains && synesis.activeFileKind == syn"
        },
        {
          "id": "synesisOntologyTopicsExplorer",
          "name": "Ontology Topics",
          "when": "synesis.hasTopics && synesis.activeFileKind == syno"
        },
        {
          "id": "synesisOntologyAnnotationExplorer",
          "name": "Ontology (Annotations)",
          "when": "synesis.hasOntologyAnnotations && synesis.activeFileKind == syn"
        },
        {
          "id": "synesisTemplateExplorer",
          "name": "Template Fields"
        }
      ]
    },
    "commands": [
      {
        "command": "synesis.lsp.loadProject",
        "title": "Synesis: LSP Load Project"
      },
      {
        "command": "synesis.reference.refresh",
        "title": "Refresh References",
        "icon": "$(refresh)"
      },
      {
        "command": "synesis.reference.filter",
        "title": "Filter References",
        "icon": "$(filter)"
      },
      {
        "command": "synesis.reference.filterActive",
        "title": "Filter References",
        "icon": {
          "light": "icons/filter-red.svg",
          "dark": "icons/filter-red.svg"
        }
      },
      {
        "command": "synesis.code.refresh",
        "title": "Refresh Codes",
        "icon": "$(refresh)"
      },
      {
        "command": "synesis.code.filter",
        "title": "Filter Codes",
        "icon": "$(filter)"
      },
      {
        "command": "synesis.code.filterActive",
        "title": "Filter Codes",
        "icon": {
          "light": "icons/filter-red.svg",
          "dark": "icons/filter-red.svg"
        }
      },
      {
        "command": "synesis.relation.refresh",
        "title": "Refresh Relations",
        "icon": "$(refresh)"
      },
      {
        "command": "synesis.relation.filter",
        "title": "Filter Relations",
        "icon": "$(filter)"
      },
      {
        "command": "synesis.relation.filterActive",
        "title": "Filter Relations",
        "icon": {
          "light": "icons/filter-red.svg",
          "dark": "icons/filter-red.svg"
        }
      },
      {
        "command": "synesis.ontology.refresh",
        "title": "Refresh Ontology Topics",
        "icon": "$(refresh)"
      },
      {
        "command": "synesis.ontology.filter",
        "title": "Filter Ontology Topics",
        "icon": "$(filter)"
      },
      {
        "command": "synesis.ontology.filterActive",
        "title": "Filter Ontology Topics",
        "icon": {
          "light": "icons/filter-red.svg",
          "dark": "icons/filter-red.svg"
        }
      },
      {
        "command": "synesis.ontology.annotation.refresh",
        "title": "Refresh Ontology (Annotations)",
        "icon": "$(refresh)"
      },
      {
        "command": "synesis.ontology.annotation.filter",
        "title": "Filter Ontology (Annotations)",
        "icon": "$(filter)"
      },
      {
        "command": "synesis.ontology.annotation.filterActive",
        "title": "Filter Ontology (Annotations)",
        "icon": {
          "light": "icons/filter-red.svg",
          "dark": "icons/filter-red.svg"
        }
      },
      {
        "command": "synesis.showGraph",
        "title": "Synesis: Show Relation Graph (All)"
      },
      {
        "command": "synesis.showGraphPerFile",
        "title": "Synesis: Show Relation Graph per File"
      },
      {
        "command": "synesis.showGraphPerItem",
        "title": "Synesis: Show Relation Graph per Item"
      },
      {
        "command": "synesis.template.refresh",
        "title": "Refresh Template Fields",
        "icon": "$(refresh)"
      },
      {
        "command": "synesis.template.goToField",
        "title": "Go to Field in Template"
      },
      {
        "command": "synesis.showAbstract",
        "title": "Synesis: Show Abstract"
      },
      {
        "command": "synesis.openLocation",
        "title": "Open Location"
      },
      {
        "command": "synesis.code.goToDefinition",
        "title": "Go to Definition",
        "icon": "$(go-to-file)"
      },
      {
        "command": "synesis.code.rename",
        "title": "Rename Code"
      },
      {
        "command": "synesis.reference.rename",
        "title": "Rename Reference"
      },
      {
        "command": "synesis.coder.codeSelection",
        "title": "Synesis: Code Selection"
      }
    ],
    "keybindings": [
      {
        "command": "synesis.showGraph",
        "key": "ctrl+alt+g",
        "mac": "cmd+shift+g",
        "when": "editorTextFocus && editorLangId == synesis && synesis.hasChains"
      },
      {
        "command": "synesis.showGraphPerFile",
        "key": "ctrl+alt+f",
        "mac": "cmd+shift+f",
        "when": "editorTextFocus && editorLangId == synesis && synesis.hasChains"
      },
      {
        "command": "synesis.showGraphPerItem",
        "key": "ctrl+alt+i",
        "mac": "cmd+alt+i",
        "when": "editorTextFocus && editorLangId == synesis && synesis.hasChains"
      },
      {
        "command": "synesis.showAbstract",
        "key": "ctrl+shift+a",
        "mac": "cmd+shift+a",
        "when": "editorTextFocus && editorLangId == synesis"
      },
      {
        "command": "synesis.code.goToDefinition",
        "key": "F12",
        "when": "focusedView == synesisCodeExplorer"
      },
      {
        "command": "synesis.code.rename",
        "key": "F2",
        "when": "focusedView == synesisCodeExplorer"
      },
      {
        "command": "synesis.reference.rename",
        "key": "F2",
        "when": "focusedView == synesisReferenceExplorer"
      },
      {
        "command": "synesis.coder.codeSelection",
        "key": "ctrl+shift+i",
        "mac": "cmd+shift+i",
        "when": "editorTextFocus && editorLangId == synesis && editorHasSelection && synesis.activeFileKind == syn"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "synesis.reference.refresh",
          "when": "view == synesisReferenceExplorer",
          "group": "navigation"
        },
        {
          "command": "synesis.reference.filter",
          "when": "view == synesisReferenceExplorer && !synesis.reference.filterActive",
          "group": "navigation"
        },
        {
          "command": "synesis.reference.filterActive",
          "when": "view == synesisReferenceExplorer && synesis.reference.filterActive",
          "group": "navigation"
        },
        {
          "command": "synesis.code.refresh",
          "when": "view == synesisCodeExplorer",
          "group": "navigation"
        },
        {
          "command": "synesis.code.filter",
          "when": "view == synesisCodeExplorer && !synesis.code.filterActive",
          "group": "navigation"
        },
        {
          "command": "synesis.code.filterActive",
          "when": "view == synesisCodeExplorer && synesis.code.filterActive",
          "group": "navigation"
        },
        {
          "command": "synesis.relation.refresh",
          "when": "view == synesisRelationExplorer && synesis.hasChains",
          "group": "navigation"
        },
        {
          "command": "synesis.relation.filter",
          "when": "view == synesisRelationExplorer && synesis.hasChains && !synesis.relation.filterActive",
          "group": "navigation"
        },
        {
          "command": "synesis.relation.filterActive",
          "when": "view == synesisRelationExplorer && synesis.hasChains && synesis.relation.filterActive",
          "group": "navigation"
        },
        {
          "command": "synesis.ontology.refresh",
          "when": "view == synesisOntologyTopicsExplorer && synesis.hasTopics && synesis.activeFileKind == syno",
          "group": "navigation"
        },
        {
          "command": "synesis.ontology.filter",
          "when": "view == synesisOntologyTopicsExplorer && synesis.hasTopics && synesis.activeFileKind == syno && !synesis.ontology.filterActive",
          "group": "navigation"
        },
        {
          "command": "synesis.ontology.filterActive",
          "when": "view == synesisOntologyTopicsExplorer && synesis.hasTopics && synesis.activeFileKind == syno && synesis.ontology.filterActive",
          "group": "navigation"
        },
        {
          "command": "synesis.ontology.annotation.refresh",
          "when": "view == synesisOntologyAnnotationExplorer && synesis.hasOntologyAnnotations && synesis.activeFileKind == syn",
          "group": "navigation"
        },
        {
          "command": "synesis.ontology.annotation.filter",
          "when": "view == synesisOntologyAnnotationExplorer && synesis.hasOntologyAnnotations && synesis.activeFileKind == syn && !synesis.ontology.annotation.filterActive",
          "group": "navigation"
        },
        {
          "command": "synesis.ontology.annotation.filterActive",
          "when": "view == synesisOntologyAnnotationExplorer && synesis.hasOntologyAnnotations && synesis.activeFileKind == syn && synesis.ontology.annotation.filterActive",
          "group": "navigation"
        },
        {
          "command": "synesis.template.refresh",
          "when": "view == synesisTemplateExplorer",
          "group": "navigation"
        }
      ],
      "commandPalette": [
        {
          "command": "synesis.relation.filterActive",
          "when": "false"
        },
        {
          "command": "synesis.reference.filterActive",
          "when": "false"
        },
        {
          "command": "synesis.code.filterActive",
          "when": "false"
        },
        {
          "command": "synesis.ontology.filterActive",
          "when": "false"
        },
        {
          "command": "synesis.ontology.annotation.filterActive",
          "when": "false"
        },
        {
          "command": "synesis.template.goToField",
          "when": "false"
        }
      ],
      "editor/context": [
        {
          "command": "synesis.showGraphPerFile",
          "when": "editorLangId == synesis && synesis.hasChains && synesis.activeFileKind == syn",
          "group": "synesis@1"
        },
        {
          "command": "synesis.showGraphPerItem",
          "when": "editorLangId == synesis && synesis.hasChains && synesis.activeFileKind == syn",
          "group": "synesis@2"
        },
        {
          "command": "synesis.coder.codeSelection",
          "when": "editorLangId == synesis && editorHasSelection && synesis.activeFileKind == syn",
          "group": "1_modification"
        }
      ],
      "view/item/context": [
        {
          "command": "synesis.code.goToDefinition",
          "when": "view == synesisCodeExplorer && viewItem == code",
          "group": "navigation"
        },
        {
          "command": "synesis.reference.rename",
          "when": "view == synesisReferenceExplorer && viewItem == reference",
          "group": "7_modification"
        }
      ]
    },
    "configurationDefaults": {
      "[synesis]": {
        "editor.semanticHighlighting.enabled": true
      }
    },
    "configuration": {
      "title": "Synesis",
      "properties": {
        "synesisExplorer.lsp.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable Synesis LSP integration."
        },
        "synesisExplorer.lsp.pythonPath": {
          "type": "string",
          "default": "synesis-lsp",
          "scope": "machine",
          "description": "Synesis LSP executable path. Machine-scoped: cannot be overridden by a workspace's .vscode/settings.json, so opening an untrusted project cannot redirect the executable that is launched."
        },
        "synesisExplorer.lsp.args": {
          "type": "array",
          "default": [],
          "scope": "machine",
          "description": "Arguments passed to the Synesis LSP executable (e.g. [\"-m\", \"synesis_lsp\"]). Machine-scoped for the same reason as lsp.pythonPath.",
          "items": {
            "type": "string"
          }
        },
        "synesisExplorer.diagnostics.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable inline diagnostics (error/warning squiggles) from the Synesis LSP."
        },
        "synesisExplorer.inlayHints.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Show inline hints after @bibrefs (e.g. \"(Author, Year)\")."
        },
        "synesisExplorer.semanticHighlighting.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable AST-based semantic syntax highlighting (more accurate than TextMate grammar). Requires Synesis Dark or Synesis Light theme, or a theme with semanticTokenColors support."
        },
        "synesisExplorer.completion.autoImportCodes": {
          "type": "boolean",
          "default": true,
          "description": "Include ontology codes from the compiled project in autocomplete suggestions."
        },
        "synesisExplorer.coder.path": {
          "type": "string",
          "default": "synesis-coder",
          "scope": "machine",
          "description": "Path to the synesis-coder executable. Machine-scoped: cannot be overridden by a workspace's .vscode/settings.json."
        }
      }
    }
  },
  "capabilities": {
    "untrustedWorkspaces": {
      "supported": "limited",
      "description": "In an untrusted workspace the language server and synesis-coder are launched only from the machine-level executable paths, never from a path supplied by the workspace."
    }
  },
  "scripts": {
    "build": "node esbuild.js",
    "build:watch": "node esbuild.js --watch",
    "test": "npm run test:unit && npm run test:integration",
    "test:unit": "mocha \"test/unit/**/*.test.js\" --timeout 5000",
    "test:integration": "vscode-test",
    "test:watch": "mocha \"test/unit/**/*.test.js\" --watch --timeout 5000",
    "lint": "eslint .",
    "compile": "npm run build",
    "watch": "npm run build:watch",
    "package": "vsce package",
    "vscode:prepublish": "npm run build"
  },
  "dependencies": {
    "bibtex-parse-js": "^0.0.24",
    "vscode-languageclient": "^9.0.0"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^14.x",
    "@types/vscode": "^1.60.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^3.0.0",
    "@vscode/vsce": "^3.9.2",
    "ajv": "^8.20.0",
    "chai": "^4.3.0",
    "esbuild": "^0.20.2",
    "eslint": "^8.0.0",
    "mocha": "^10.0.0"
  }
}
